# Mentra MiniApp Config
PORT=3000
API_URL=https://tu-api-desplegada.com/api/v1/query
ANALYZE_IMAGE_URL=https://tu-api-desplegada.com/api/v1/analyze-image
APP_ID=tu-app-id
APP_NAME=DevPaul AI Assistant
MENTRAOS_API_KEY=your_api_key_from_console

# Groq API Configuration (powered by Groq)
# Get your API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_STREAM_URL=https://api.groq.com/openai/v1/chat/completions

# Custom System Prompts (optional)
GROQ_SYSTEM_PROMPT=Eres DevPaul, un asistente de IA amigable y útil. Responde de forma concisa y clara en español.
GROQ_VISION_SYSTEM_PROMPT=Describe lo que ves en esta imagen de forma breve y clara en español.
